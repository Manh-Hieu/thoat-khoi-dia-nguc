  m_Script: {fileID: 11500000, guid: 774a8757c51ee8b4788e5669d3278ab1, type: 3}
  m_Name: Chapter1_FinCredit
  m_EditorClassIdentifier: Assembly-CSharp::EscapeFromHell.Systems.DialogueData
  lines:
  - speakerName: Minh
    speakerPortrait: {fileID: 0}
    text: "L\u1EA1i l\xE0 tin nh\u1EAFn \u0111\xF2i n\u1EE3 t\u1EEB b\xEAn app vay
      ti\u1EC1n..."
  - speakerName: Minh
    speakerPortrait: {fileID: 0}
    text: "H\u1ECD d\u1ECDa s\u1EBD li\xEAn h\u1EC7 v\u1EDBi gia \u0111\xECnh v\xE0
      ng\u01B0\u1EDDi th\xE2n n\u1EBFu kh\xF4ng tr\u1EA3 n\u1EE3 tr\u01B0\u1EDBc
      chi\u1EC1u nay."
  - speakerName: Minh
    speakerPortrait: {fileID: 0}
    text: "N\u1EBFu m\u1EB9 bi\u1EBFt chuy\u1EC7n m\xECnh vay n\u1EE3 app th\u1EBF
      n\xE0y, m\u1EB9 ch\u1EAFc s\u1EBD s\u1ED1c l\u1EAFm... M\xECnh ph\u1EA3i l\xE0m
      sao \u0111\xE2y?"
  choices: []
