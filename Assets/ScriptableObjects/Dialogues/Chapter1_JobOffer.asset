  m_Script: {fileID: 11500000, guid: 774a8757c51ee8b4788e5669d3278ab1, type: 3}
  m_Name: Chapter1_JobOffer
  m_EditorClassIdentifier: Assembly-CSharp::EscapeFromHell.Systems.DialogueData
  lines:
  - speakerName: Minh
    speakerPortrait: {fileID: 0}
    text: "\u1EE6a... Tuy\u1EC3n nh\xE2n vi\xEAn v\u0103n ph\xF2ng \u1EDF Campuchia
      l\u01B0\u01A1ng 38 \u0111\u1EBFn 50 tri\u1EC7u/th\xE1ng c\u01A1 \xE1? L\u01B0\u01A1ng
      cao b\u1EA5t th\u01B0\u1EDDng v\u1EADy?"
  - speakerName: Minh
    speakerPortrait: {fileID: 0}
    text: "Khoan \u0111\xE3... Campuchia? Bavet? M\xECnh nghe b\u1EA1n b\xE8 c\u1EA3nh
      b\xE1o khu \u0111\xF3 to\xE0n casino l\u1EEBa \u0111\u1EA3o v\xE0 bu\xF4n b\xE1n
      ng\u01B0\u1EDDi th\xF4i."
  - speakerName: Minh
    speakerPortrait: {fileID: 0}
    text: "S\u1ED1 l\u1EA1, l\u01B0\u01A1ng kh\xF4ng t\u01B0\u1EDFng, \u0111\u1ECBa
      \u0111i\u1EC3m \u0111\xE1ng nghi... \u0110\xE2y ch\u1EAFc ch\u1EAFn l\xE0 b\u1EABy
      l\u1EEBa \u0111\u1EA3o r\u1ED3i. M\xECnh ph\u1EA3i x\xF3a tin nh\u1EAFn n\xE0y
      \u0111i."
  choices: []
