  m_Script: {fileID: 11500000, guid: 774a8757c51ee8b4788e5669d3278ab1, type: 3}
  m_Name: Chapter1_Intro
  m_EditorClassIdentifier: Assembly-CSharp::EscapeFromHell.Systems.DialogueData
  lines:
  - speakerName: Minh
    speakerPortrait: {fileID: 0}
    text: "U\u1EA7y... \u0110\u1EA7u \u0111au b\xFAa b\u1ED5. M\u1EA5y gi\u1EDD r\u1ED3i
      nh\u1EC9?"
  - speakerName: Minh
    speakerPortrait: {fileID: 0}
    text: "L\u1EA1i m\u1ED9t ng\xE0y n\u1EEFa th\u1EE9c d\u1EADy trong c\u0103n ph\xF2ng
      tr\u1ECD ch\u1EADt h\u1EB9p n\xE0y..."
  - speakerName: Minh
    speakerPortrait: {fileID: 0}
    text: "M\xECnh c\u1EA7n t\xECm c\xE1ch thanh to\xE1n \u0111\u1ED1ng h\xF3a \u0111\u01A1n
      th\xE1ng n\xE0y, r\u1ED3i m\u1EDF laptop l\xEAn xem c\xF3 vi\u1EC7c n\xE0o
      m\u1EDBi kh\xF4ng. \xC0, ki\u1EC3m tra c\u1EA3 \u0111i\u1EC7n tho\u1EA1i n\u1EEFa."
  choices: []
