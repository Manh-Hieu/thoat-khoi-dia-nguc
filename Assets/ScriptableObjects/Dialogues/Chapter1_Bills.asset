  m_Script: {fileID: 11500000, guid: 774a8757c51ee8b4788e5669d3278ab1, type: 3}
  m_Name: Chapter1_Bills
  m_EditorClassIdentifier: Assembly-CSharp::EscapeFromHell.Systems.DialogueData
  lines:
  - speakerName: Minh
    speakerPortrait: {fileID: 0}
    text: "T\u1EDD th\xF4ng b\xE1o ti\u1EC1n nh\xE0..."
  - speakerName: "H\xF3a \u0110\u01A1n"
    speakerPortrait: {fileID: 0}
    text: "T\u1ED5ng ti\u1EC1n nh\xE0 + \u0111i\u1EC7n + n\u01B0\u1EDBc th\xE1ng
      n\xE0y: 3,500,000\u0111.\nH\u1EA1n ch\xF3t thanh to\xE1n: ng\xE0y 15. Qu\xE1
      h\u1EA1n s\u1EBD c\u1EAFt \u0111i\u1EC7n n\u01B0\u1EDBc."
  - speakerName: Minh
    speakerPortrait: {fileID: 0}
    text: "H\xF4m nay \u0111\xE3 l\xE0 ng\xE0y 11 r\u1ED3i... Trong t\xE0i kho\u1EA3n
      ch\u1EC9 c\xF2n \u0111\xFAng 500k. Ki\u1EC3u n\xE0y ch\u1EAFc b\u1ECB \u0111u\u1ED5i
      ra \u0111\u01B0\u1EDDng m\u1EA5t."
  choices: []
