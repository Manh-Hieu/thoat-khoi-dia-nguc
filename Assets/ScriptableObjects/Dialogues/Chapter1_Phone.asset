  m_Script: {fileID: 11500000, guid: 774a8757c51ee8b4788e5669d3278ab1, type: 3}
  m_Name: Chapter1_Phone
  m_EditorClassIdentifier: Assembly-CSharp::EscapeFromHell.Systems.DialogueData
  lines:
  - speakerName: Minh
    speakerPortrait: {fileID: 0}
    text: "M\u1EDF \u0111i\u1EC7n tho\u1EA1i l\xEAn xem n\xE0o... C\xF3 tin nh\u1EAFn
      m\u1EDBi t\u1EEB M\u1EB9."
  - speakerName: "M\u1EB9"
    speakerPortrait: {fileID: 0}
    text: "Minh \u01A1i, th\xE1ng n\xE0y d\u01B0\u1EDBi qu\xEA m\u1EA5t m\xF9a qu\xE1,
      b\u1ED1 con l\u1EA1i \u0111au ch\xE2n. Con xem c\xF3 g\u1EEDi v\u1EC1 cho m\u1EB9
      \xEDt ti\u1EC1n thu\u1ED1c thang cho b\u1ED1 \u0111\u01B0\u1EE3c kh\xF4ng?"
  - speakerName: Minh
    speakerPortrait: {fileID: 0}
    text: "B\u1ED1 m\u1EB9 \u1EDF qu\xEA \u0111ang kh\xF3 kh\u0103n nh\u01B0 th\u1EBF...
      M\xE0 m\xECnh v\xF4 d\u1EE5ng qu\xE1, ngay c\u1EA3 ti\u1EC1n ph\xF2ng tr\u1ECD
      c\xF2n ch\u01B0a \u0111\xF3ng n\u1ED5i, l\u1EA5y \u0111\xE2u ra ti\u1EC1n g\u1EEDi
      v\u1EC1 lo thu\u1ED1c thang cho b\u1ED1 b\xE2y gi\u1EDD..."
  choices: []
