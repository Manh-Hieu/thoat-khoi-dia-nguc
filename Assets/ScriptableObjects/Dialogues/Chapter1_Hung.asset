  m_Script: {fileID: 11500000, guid: 774a8757c51ee8b4788e5669d3278ab1, type: 3}
  m_Name: Chapter1_Hung
  m_EditorClassIdentifier: Assembly-CSharp::EscapeFromHell.Systems.DialogueData
  lines:
  - speakerName: Minh
    speakerPortrait: {fileID: 0}
    text: "H\u1ECFi th\u0103m H\xF9ng xem c\xF3 xoay s\u1EDF \u0111\u01B0\u1EE3c
      \xEDt ti\u1EC1n kh\xF4ng, ai ng\u1EDD n\xF3 c\u0169ng \u0111ang c\u1EF1c kh\u1ED5..."
  - speakerName: Minh
    speakerPortrait: {fileID: 0}
    text: "C\xF4ng ty n\u1EE3 l\u01B0\u01A1ng, m\u1ECDi ng\u01B0\u1EDDi ai c\u0169ng
      \u0111ang ph\u1EA3i v\u1EADt l\u1ED9n. H\u1ECFi m\u01B0\u1EE3n ti\u1EC1n l\xFAc
      n\xE0y th\u1EADt s\u1EF1 kh\xF4ng \u0111\xFAng ch\xFAt n\xE0o..."
  choices: []
