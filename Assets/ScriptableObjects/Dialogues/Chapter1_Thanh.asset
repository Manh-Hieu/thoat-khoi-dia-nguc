  m_Script: {fileID: 11500000, guid: 774a8757c51ee8b4788e5669d3278ab1, type: 3}
  m_Name: Chapter1_Thanh
  m_EditorClassIdentifier: Assembly-CSharp::EscapeFromHell.Systems.DialogueData
  lines:
  - speakerName: Minh
    speakerPortrait: {fileID: 0}
    text: "\u0110\u1EBFn c\u1EA3 Th\xE0nh c\u0169ng nh\u1EAFn tin \u0111\xF2i ti\u1EC1n..."
  - speakerName: Minh
    speakerPortrait: {fileID: 0}
    text: "L\xFAc tr\u01B0\u1EDBc k\u1EB9t qu\xE1 vay n\xF3 1 tri\u1EC7u... gi\u1EDD
      n\xF3 c\u1EA7n g\u1EA5p m\xE0 m\xECnh kh\xF4ng c\xF3 m\u1ED9t xu \u0111\u1EC3
      tr\u1EA3."
  - speakerName: Minh
    speakerPortrait: {fileID: 0}
    text: "Nh\xECn tin nh\u1EAFn c\u1EE7a n\xF3 m\xE0 th\u1EA5y t\u1ED9i l\u1ED7i
      qu\xE1... Th\xF4i, gi\u1EDD c\xF3 tr\u1EA3 l\u1EDDi c\u0169ng ch\u1EB3ng gi\u1EA3i
      quy\u1EBFt \u0111\u01B0\u1EE3c g\xEC, m\xECnh c\xF2n kh\xF4ng bi\u1EBFt ng\xE0y
      mai l\u1EA5y g\xEC \u0103n."
  choices: []
