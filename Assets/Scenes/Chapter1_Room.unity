  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<size=11><color=#9aa0a6>Kho\u1EA3ng 124.000 k\u1EBFt qu\u1EA3 (0,32 gi\xE2y)</color></size><br><br><color=#8ab4f8><size=13><b>1.
    Th\u1EF1c T\u1EADp Sinh L\u1EADp Tr\xECnh Unity - JoyGame Studio</b></size></color><br><color=#9aa0a6><size=10>https://joygamestudio.vn/tuyen-dung/intern-unity</size></color><br>\u2022
    Y\xEAu c\u1EA7u: C\xF3 s\u1EA3n ph\u1EA9m game t\u1EF1 l\xE0m, hi\u1EC3u r\xF5
    C# v\xE0 c\u1EA5u tr\xFAc d\u1EEF li\u1EC7u.<br>\u2022 L\u01B0\u01A1ng h\u1ED7
    tr\u1EE3: 1.000.000\u0111/th\xE1ng. Th\u1EED vi\u1EC7c kh\xF4ng l\u01B0\u01A1ng
    2 th\xE1ng.<br><br><color=#8ab4f8><size=13><b>2. L\u1EADp Tr\xECnh Vi\xEAn Web
    (Fresher) - NovaTech Group</b></size></color><br><color=#9aa0a6><size=10>https://novatech.com/careers/web-fresher</size></color><br>\u2022
    Y\xEAu c\u1EA7u: C\xF3 t\u1ED1i thi\u1EC3u 1 n\u0103m kinh nghi\u1EC7m l\xE0m
    vi\u1EC7c th\u1EF1c t\u1EBF t\u1EA1i doanh nghi\u1EC7p.<br>\u2022 M\u1EE9c l\u01B0\u01A1ng:
    6.000.000\u0111 - 8.000.000\u0111. Ph\u1ECFng v\u1EA5n k\u1EF9 thu\u1EADt 3 v\xF2ng.<br><br><color=#33cc66><size=13><b>3.
    [HOT] Vi\u1EC7c L\xE0m N\u01B0\u1EDBc Ngo\xE0i L\u01B0\u01A1ng Cao - Tuy\u1EC3n
    K\u1EF9 Thu\u1EADt Vi\xEAn M\xE1y T\xEDnh (Campuchia)</b></size></color><br><color=#9aa0a6><size=10>https://vieclamnuocngoai.com/tuyen-dung/cambodia-tech</size></color><br>\u2022
    M\u1EE9c l\u01B0\u01A1ng: 1.000.000\u0111 - 1.500.000\u0111/ng\xE0y (Bao \u0103n
    \u1EDF to\xE0n b\u1ED9, xe \u0111\u01B0a \u0111\xF3n).<br><br><color=#ff3366><size=13><b>4.
    [\u0110\u1ED4I V\u1EACN] B\u1EA1n \u0110ang G\u1EB7p Xui X\u1EBBo? Kh\xF4ng T\xECm
    \u0110\u01B0\u1EE3c Vi\u1EC7c L\xE0m? Click Ngay!</b></size></color><br><color=#9aa0a6><size=10>https://thaydoivanmenh.com.vn/dich-vu-giai-han</size></color><br>\u2022
    B\u1EA1n c\u1EA3m th\u1EA5y b\u1EBF t\u1EAFc v\xEC th\u1EA5t nghi\u1EC7p, n\u1EE3
    n\u1EA7n ch\u1ED3ng ch\u1EA5t? Ch\xFAng t\xF4i c\xF3 gi\u1EA3i ph\xE1p thay \u0111\u1ED5i
    v\u1EADn m\u1EC7nh c\u1EE7a b\u1EA1n ngay l\u1EADp t\u1EE9c.<br>\u2022 \u0110\u0103ng
    k\xFD d\u1ECBch v\u1EE5 gi\u1EA3i h\u1EA1n t\xE2m linh \u0111\u1EB7c bi\u1EC7t
    gi\xFAp t\u0103ng c\u01A1 h\u1ED9i tr\xFAng tuy\u1EC3n l\xEAn 100%.<br><br><color=#ffcc00><i>C\u1EA3nh
    b\xE1o th\u1ECB tr\u01B0\u1EDDng:</i></color> <i>Th\u1ECB tr\u01B0\u1EDDng tuy\u1EC3n
    d\u1EE5ng IT n\u0103m 2026 \u0111ang c\xF3 m\u1EE9c \u0111\u1ED9 c\u1EA1nh tranh
    r\u1EA5t cao. C\u1EA3nh gi\xE1c v\u1EDBi c\xE1c tin tuy\u1EC3n d\u1EE5ng vi\u1EC7c
    nh\u1EB9 l\u01B0\u01A1ng cao \u1EDF n\u01B0\u1EDBc ngo\xE0i, n\u1EA1p ti\u1EC1n
    c\u1ECDc l\xE0m nhi\u1EC7m v\u1EE5.</i>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
