    m_PersistentCalls:
      m_Calls: []
  m_text: "H\u01A1n 60 c\xF4ng nh\xE2n t\u1EA1i khu c\xF4ng nghi\u1EC7p B\xECnh D\u01B0\u01A1ng
    \u0111\xE3 t\u1EADp trung tr\u01B0\u1EDBc c\u1ED5ng nh\xE0 m\xE1y \u0111\u1EC3
    ph\u1EA3n \u0111\u1ED1i vi\u1EC7c b\u1ECB n\u1EE3 l\u01B0\u01A1ng ba th\xE1ng
    li\xEAn ti\u1EBFp. C\xF4ng ty TNHH s\u1EA3n xu\u1EA5t \xC1nh D\u01B0\u01A1ng
    (ch\u1EE7 s\u1EDF h\u1EEFu nh\xE0 m\xE1y) tuy\xEAn b\u1ED1 \"\u0111ang g\u1EB7p
    kh\xF3 kh\u0103n t\xE0i ch\xEDnh t\u1EA1m th\u1EDDi\" v\xE0 h\u1EE9a s\u1EBD
    thanh to\xE1n trong v\xF2ng 30 ng\xE0y.\n\nTuy nhi\xEAn \u0111\xE2y l\xE0 l\u1EA7n
    th\u1EE9 t\u01B0 c\xF4ng ty \u0111\u01B0a ra l\u1EDDi h\u1EE9a t\u01B0\u01A1ng
    t\u1EF1. Nhi\u1EC1u c\xF4ng nh\xE2n cho bi\u1EBFt h\u1ECD kh\xF4ng c\xF3 ti\u1EC1n
    mua g\u1EA1o hay tr\u1EA3 ti\u1EC1n thu\xEA ph\xF2ng tr\u1ECD. \u0110\u01A1n
    kh\u1EDFi ki\u1EC7n t\u1EADp th\u1EC3 b\u1ECB t\xF2a \xE1n tr\u1EA3 l\u1EA1i
    v\xEC thi\u1EBFu ch\u1EE9ng t\u1EEB h\u1EE3p l\u1EC7."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
