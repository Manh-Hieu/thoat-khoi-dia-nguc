  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Theo s\u1ED1 li\u1EC7u T\u1ED5ng c\u1EE5c Th\u1ED1ng k\xEA c\xF4ng b\u1ED1
    h\xF4m qua, ch\u1EC9 s\u1ED1 gi\xE1 ti\xEAu d\xF9ng (CPI) th\xE1ng 3/2024 t\u0103ng
    4,2% so v\u1EDBi c\xF9ng k\u1EF3 n\u0103m ngo\xE1i. \u0110\xE2y l\xE0 m\u1EE9c
    t\u0103ng cao nh\u1EA5t k\u1EC3 t\u1EEB qu\xFD II/2023.\n\nGi\xE1 th\u1EF1c ph\u1EA9m,
    x\u0103ng d\u1EA7u v\xE0 ti\u1EC1n thu\xEA nh\xE0 l\xE0 ba nh\xF3m t\u0103ng
    m\u1EA1nh nh\u1EA5t. Nhi\u1EC1u h\u1ED9 gia \u0111\xECnh thu nh\u1EADp th\u1EA5p
    cho bi\u1EBFt h\u1ECD ph\u1EA3i c\u1EAFt gi\u1EA3m chi ti\xEAu xu\u1ED1ng m\u1EE9c
    t\u1ED1i thi\u1EC3u \u0111\u1EC3 trang tr\u1EA3i qua th\xE1ng.\n\nChuy\xEAn gia
    kinh t\u1EBF Tr\u1EA7n V\u0103n Minh (\u0110\u1EA1i h\u1ECDc Kinh t\u1EBF TP.HCM)
    nh\u1EADn \u0111\u1ECBnh: \"N\u1EBFu l\u1EA1m ph\xE1t ti\u1EBFp t\u1EE5c \u0111\xE0
    n\xE0y, s\u1EE9c mua c\u1EE7a ng\u01B0\u1EDDi d\xE2n s\u1EBD suy gi\u1EA3m nghi\xEAm
    tr\u1ECDng trong c\xE1c qu\xFD t\u1EDBi.\""
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
