  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "C\u01A1 quan C\u1EA3nh s\xE1t \u0111i\u1EC1u tra (B\u1ED9 C\xF4ng an)
    v\u1EEBa ph\xE1 th\xE0nh c\xF4ng \u0111\u01B0\u1EDDng d\xE2y l\u1EEBa \u0111\u1EA3o
    tr\u1EF1c tuy\u1EBFn quy m\xF4 l\u1EDBn, b\u1EAFt gi\u1EEF 14 \u0111\u1ED1i t\u01B0\u1EE3ng
    v\xE0 thu gi\u1EEF tang v\u1EADt tr\u1ECB gi\xE1 h\xE0ng ch\u1EE5c t\u1EF7 \u0111\u1ED3ng.\n\n\u0110\u01B0\u1EDDng
    d\xE2y n\xE0y ho\u1EA1t \u0111\u1ED9ng t\u1EEB n\u0103m 2022, nh\u1EAFm v\xE0o
    nh\u1EEFng ng\u01B0\u1EDDi \u0111ang t\xECm vi\u1EC7c l\xE0m ho\u1EB7c mu\u1ED1n
    ki\u1EBFm th\xEAm thu nh\u1EADp. C\xE1c \u0111\u1ED1i t\u01B0\u1EE3ng s\u1EED
    d\u1EE5ng m\u1EA1ng x\xE3 h\u1ED9i \u0111\u1EC3 ti\u1EBFp c\u1EADn n\u1EA1n nh\xE2n,
    d\u1EE5 d\u1ED7 h\u1ECD \u0111\u1EB7t c\u1ECDc \"ph\xED b\u1EA3o l\xE3nh\" ho\u1EB7c
    \"v\u1ED1n kh\u1EDFi \u0111\u1ED9ng\" v\u1EDBi l\u1EDDi h\u1EE9a h\xE3o v\u1EC1
    c\xF4ng vi\u1EC7c l\u01B0\u01A1ng cao t\u1EA1i n\u01B0\u1EDBc ngo\xE0i.\n\nTheo
    \u0111i\u1EC1u tra, t\u1ED5ng s\u1ED1 ti\u1EC1n b\u1ECB chi\u1EBFm \u0111o\u1EA1t
    l\xEAn \u0111\u1EBFn 87 t\u1EF7 \u0111\u1ED3ng t\u1EEB h\u01A1n 400 n\u1EA1n
    nh\xE2n t\u1EA1i 23 t\u1EC9nh th\xE0nh. Nhi\u1EC1u n\u1EA1n nh\xE2n \u0111\xE3
    ph\u1EA3i b\xE1n \u0111\u1EA5t, vay n\u1EB7ng l\xE3i \u0111\u1EC3 c\xF3 ti\u1EC1n
    theo y\xEAu c\u1EA7u c\u1EE7a b\u1ECDn l\u1EEBa \u0111\u1EA3o."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
